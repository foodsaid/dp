# =============================================================================
# DP v0.3.2 — 开发环境最小化配置 (7 核心容器, 无 SSO/监控)
# =============================================================================
# 用法: cp .env.dev.example .env → 填写密码 → bash scripts/dev-up.sh
# 完整模板 (含 SSO/监控/生产): 参考 .env.example
# =============================================================================
# 所有密码字段为空 — 空密码 = 容器启动失败 = 强制你配置!
# 生成密码: openssl rand -base64 32
# =============================================================================

# ======================== Docker Compose ========================
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
DP_DOCKER_NETWORK=n8network

# ======================== 全局 ========================
DP_DATA_DIR=./data
SYSTEM_TIMEZONE=UTC
DP_COMPANY_CODE=DEFAULT
DP_COMPANY_NAME=Digital Platform
DP_CONTACT_EMAIL=admin@example.com
DP_DOMAIN=127.0.0.1

# ======================== PostgreSQL ========================
# [必填] 超级用户密码
DP_DB_ROOT_PASSWORD=
# 数据库名 (留空默认 dp)
DP_DB_NAME=
# 应用用户名 (留空默认 dp_app)
DP_DB_USER=
# [必填] 应用用户密码
DP_DB_PASSWORD=
DP_DB_PORT=5432

# ======================== Redis ========================
# [必填] 工作流队列 Redis 密码
DP_REDIS_WF_PASSWORD=
DP_REDIS_WF_PORT=6379
# [必填] BI 缓存 Redis 密码
DP_REDIS_BI_PASSWORD=
DP_REDIS_BI_PORT=6380

# ======================== n8n ========================
DP_WF_PORT=5678
WEBHOOK_URL=http://localhost:5678
N8N_EDITOR_BASE_URL=http://localhost:5678/
# [必填] 凭据加密密钥 — 首次生成后永不更改!
N8N_ENCRYPTION_KEY=
N8N_API_KEY=
# 编辑器账号: 首次访问 n8n UI 时通过设置向导创建 (存储在 wf.user 表, 非 SSO 管理)
# 忘记密码: docker exec dp-wf n8n user-management:reset → 重新访问 UI 设置

# ======================== WMS 前端 ========================
DP_WMS_WEB_PORT=8081
ENV_NAME=development
API_BASE_URL=/api/wms
SOUND_ENABLED=true
AUTO_FOCUS_DELAY=100
DEBUG=true
APP_VERSION=v0.3.2

# ======================== BI (Superset) ========================
# [必填] BI 密钥 (≥32 字符)
DP_BI_SECRET_KEY=
# [必填] BI 管理员
DP_BI_ADMIN_USERNAME=
DP_BI_ADMIN_PASSWORD=
DP_BI_ADMIN_EMAIL=admin@example.com
DP_BI_PORT=8088

# ======================== SAP B1 (有 SAP 时填写) ========================
SAP_SL_URL=
SAP_SL_COMPANY_DB=
SAP_SL_USER=
SAP_SL_PASSWORD=
SAP_MSSQL_HOST=
SAP_MSSQL_PORT=1433
SAP_MSSQL_DATABASE=
SAP_MSSQL_USER=
SAP_MSSQL_PASSWORD=

# ======================== 网关 ========================
DP_GATEWAY_PORT=8080
