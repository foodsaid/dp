# =============================================================================
# DP v0.3.2 — Digital Platform 环境配置模板
# =============================================================================
# 用法: cp .env.example .env.dev / .env.uat / .env.prod → 修改参数
# 启动: bash scripts/dev-up.sh [--dev|--uat]
# 本文件提交至 Git。.env / .env.dev / .env.uat / .env.prod 均被 gitignore。
# =============================================================================
# 所有密码字段为空 — 空密码 = 容器启动失败 = 强制你配置!
# 生成密码: openssl rand -base64 32
# =============================================================================
#
# 三环境仅 4 个变量不同, 其余共享:
#   变量                 DEV (--dev)             UAT (--uat)             PROD
#   WEBHOOK_URL          http://localhost:5678    https://wf.domain.com   https://wf.domain.com
#   N8N_EDITOR_BASE_URL  http://localhost:5678/   https://wf.domain.com/  https://wf.domain.com/
#   ENV_NAME             development              staging                 production
#   DEBUG                true                     true                    false

# ======================== 平台 (dev-up.sh 自动检测) ========================
# CPU 架构: amd64 / arm64
DP_CPU_ARCH=amd64
# Grafana 镜像 (amd64 推荐 -oss 更轻量)
DP_GRAFANA_IMAGE=grafana/grafana-oss:12.4.1
# Docker Socket 路径 (macOS: ~/.docker/run/docker.sock, WSL2/Linux: 默认即可)
# DP_DOCKER_SOCK=/var/run/docker.sock

# ======================== Docker Compose ========================
# 生产必改为: docker-compose.yml:docker-compose.prod.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
DP_DOCKER_NETWORK=n8network

# ======================== 全局 ========================
DP_DATA_DIR=./data
SYSTEM_TIMEZONE=UTC
DP_COMPANY_CODE=DEFAULT
DP_COMPANY_NAME=Digital Platform
DP_CONTACT_EMAIL=admin@example.com
DP_DOMAIN=127.0.0.1

# ======================== PostgreSQL ========================
DP_DB_ROOT_PASSWORD=
# 数据库名 (留空默认 dp)
DP_DB_NAME=
# 应用用户名 (留空默认 dp_app)
DP_DB_USER=
DP_DB_PASSWORD=
DP_DB_PORT=5432
# RLS 业务角色 (v0.6+, 留空则跳过 RLS 角色创建)
DP_DB_RLS_PASSWORD=
# BI 只读角色 (v0.6+, 留空则跳过)
DP_DB_BI_PASSWORD=

# ======================== Redis ========================
DP_REDIS_WF_PASSWORD=
DP_REDIS_WF_PORT=6379
DP_REDIS_BI_PASSWORD=
DP_REDIS_BI_PORT=6380

# ======================== n8n ========================
# 文件节点数据目录 (留空默认 ./data/n8n-data)
DP_N8N_DATA_DIR=
DP_WF_PORT=5678
WEBHOOK_URL=http://localhost:5678
N8N_EDITOR_BASE_URL=http://localhost:5678/
# 凭据加密密钥 (必须! 首次生成后永不更改! 丢失=凭据全废)
N8N_ENCRYPTION_KEY=
# API Key (部署后填写, 用于 python3 scripts/n8n-tools/sync-workflows.py)
N8N_API_KEY=
# n8n 凭据占位符替换 (sync-workflows.py 导入工作流时自动替换 JSON 中的占位符)
# 凭据 ID 从 n8n UI → Settings → Credentials 获取
DP_CREDENTIAL_PG_ID=
DP_CREDENTIAL_PG_NAME=
DP_CREDENTIAL_MSSQL_ID=
DP_CREDENTIAL_MSSQL_NAME=
# 编辑器账号: 首次访问 n8n UI 时通过设置向导创建 (存储在 wf.user 表, 非 SSO 管理)
# 忘记密码: docker exec dp-wf n8n user-management:reset → 重新访问 UI 设置
# --- Queue 模式 (v0.4+) ---
# Worker 并发数 (每个 worker 容器的最大并行执行数, 通过 CLI flag 传入)
# N8N_WORKER_CONCURRENCY=10
# Main 入队并发限制 (防止 webhook 洪峰打满 Redis)
# N8N_CONCURRENCY_PRODUCTION_LIMIT=5
# 执行数据保留天数 (默认 7 天)
# EXECUTIONS_DATA_MAX_AGE=168
# 执行数据保留条数上限
# EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000

# ======================== WMS 前端 ========================
DP_WMS_WEB_PORT=8081
ENV_NAME=development
API_BASE_URL=/api/wms
QR_SERVICE_URL=
APP_BASE_URL=
SOUND_ENABLED=true
AUTO_FOCUS_DELAY=100
DEBUG=true
WMS_CONFIG={"DEFAULT_BIN_SUFFIX":"SYSTEM-BIN-LOCATION","BATCH_RULE":"TODAY","PROD_DATE_RULE":"TODAY"}
APP_VERSION=v0.3.2

# ======================== BI (Superset) ========================
DP_BI_SECRET_KEY=
DP_BI_ADMIN_USERNAME=
DP_BI_ADMIN_PASSWORD=
DP_BI_ADMIN_EMAIL=admin@example.com
DP_BI_PORT=8088

# ======================== SAP B1 ========================
SAP_SL_URL=
SAP_SL_COMPANY_DB=
SAP_SL_USER=
SAP_SL_PASSWORD=
SAP_MSSQL_HOST=
SAP_MSSQL_PORT=1433
SAP_MSSQL_DATABASE=
SAP_MSSQL_USER=
SAP_MSSQL_PASSWORD=

# ======================== 网关 ========================
DP_GATEWAY_PORT=8080

# ======================== Cloudflare Tunnel (生产环境) ========================
DP_TUNNEL_TOKEN=

# ======================== WMS 测试 (可选, profile: test) ========================
DP_WMS_TEST_DOMAIN=

# ======================== 可观测性 (可选, profile: monitoring) ========================
DP_PROMETHEUS_RETENTION=15d
DP_PROMETHEUS_PORT=9090
DP_ALERTMANAGER_PORT=9093
DP_GRAFANA_ADMIN_USER=admin
DP_GRAFANA_ADMIN_PASSWORD=
DP_GRAFANA_ROOT_URL=http://localhost:8080/grafana/
DP_GRAFANA_PORT=3000
DP_MONITOR_PASSWORD=
# --- Loki 日志聚合 ---
DP_LOKI_RETENTION=168h
DP_LOKI_PORT=13100
DP_ALLOY_PORT=12345

# ======================== SSO (可选, profile: sso) ========================
DP_SSO_ENABLED=false
DP_SSO_COOKIE_DOMAIN=127.0.0.1
# Authelia 外部 URL (留空默认 http://localhost:8080)
DP_SSO_BASE_URL=
# 密钥 (必须用 hex! base64 含 +/= 会破坏解析; openssl rand -hex 64)
DP_SSO_JWT_SECRET=
DP_SSO_SESSION_SECRET=
DP_SSO_STORAGE_ENCRYPTION_KEY=
DP_SSO_PORT=9091
DP_SSO_REDIS_PASSWORD=
DP_SSO_SMTP_USERNAME=
DP_SSO_SMTP_PASSWORD=
# Tunnel 域名 (可选, 留空=仅本地)
DP_SSO_TUNNEL_DOMAIN=
DP_SSO_TUNNEL_COOKIE_DOMAIN=

# ======================== HTTPS 证书 (生产环境) ========================
DP_CERTBOT_EMAIL=
