{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "日志量趋势 (按容器)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (compose_service) (rate({job=\"docker\"} [1m]))",
          "legendFormat": "{{compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" }, "fillOpacity": 50 },
          "unit": "logs/s"
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "title": "错误日志量",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\"} |~ \"(?i)(error|fatal|panic)\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background" }
    },
    {
      "title": "警告日志量",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker\"} |~ \"(?i)(warn)\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background" }
    },
    {
      "title": "活跃容器数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(sum by (compose_service) (count_over_time({job=\"docker\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background" }
    },
    {
      "title": "日志吞吐 (行/秒)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\"} [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background" }
    },
    {
      "title": "n8n 工作流日志",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"dp-wf\"} |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "数据库日志 (错误 + 慢查询)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"dp-db\"} |~ \"(?i)(error|fatal|slow|duration)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "网关日志 (4xx/5xx)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{compose_service=\"dp-gateway\"} |~ \"HTTP/[^ ]+ [45][0-9]{2} \"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "全部日志 (实时)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\", compose_service=~\"$service\"} |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["dp", "logs", "loki"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({job=\"docker\"}, compose_service)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": "label_values({job=\"docker\"}, compose_service)",
        "refresh": 2,
        "type": "query",
        "label": "容器"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "name": "search",
        "type": "textbox",
        "label": "搜索关键词"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "DP 日志",
  "uid": "dp-logs",
  "version": 1
}
