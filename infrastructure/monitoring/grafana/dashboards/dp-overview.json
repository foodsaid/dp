      "title": "活跃告警数",
      "type": "stat"
    },
    {
      "datasource": { "type": "alertmanager", "uid": "alertmanager" },
      "description": "Alertmanager 活跃告警详情列表",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
