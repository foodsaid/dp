# ==========================================================================
# Authelia 用户数据库模板
# ==========================================================================
# 实际文件: infrastructure/sso/users.yml (已 .gitignore)
# 复制本文件并修改:
#   cp users.yml.example users.yml
#
# 密码哈希生成:
#   docker exec -it dp-sso authelia crypto hash generate argon2 --password 'YOUR_PASSWORD'
#   # 或容器未运行时:
#   docker run --rm authelia/authelia:4.39.15 authelia crypto hash generate argon2 --password 'YOUR_PASSWORD'
#
# 权限分组说明:
#   admins     — 全部权限 (WMS + BI + Grafana + Prometheus + Alertmanager)
#   wms-users  — WMS 仓库管理系统
#   bi-users   — BI 数据可视化 (Superset)
#   组可自由组合: 一个用户可同时属于多个组
# ==========================================================================

users:
  # 管理员 (全部权限)
  admin:
    disabled: false
    displayname: "管理员"
    # 生成: docker exec -it dp-sso authelia crypto hash generate argon2 --password 'YOUR_PASSWORD'
    password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_WITH_REAL_HASH"
    email: admin@example.com
    groups:
      - admins
      - wms-users
      - bi-users

  # 仓库操作员 (仅 WMS)
  # operator:
  #   disabled: false
  #   displayname: "操作员"
  #   password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_WITH_REAL_HASH"
  #   email: operator@example.com
  #   groups:
  #     - wms-users

  # 数据分析师 (仅 BI)
  # analyst:
  #   disabled: false
  #   displayname: "数据分析"
  #   password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_WITH_REAL_HASH"
  #   email: analyst@example.com
  #   groups:
  #     - bi-users

  # 全业务用户 (WMS + BI, 无管理权限)
  # fulluser:
  #   disabled: false
  #   displayname: "全业务"
  #   password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_WITH_REAL_HASH"
  #   email: fulluser@example.com
  #   groups:
  #     - wms-users
  #     - bi-users
